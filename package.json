{
  "name": "mapequation",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "serve:export": "node scripts/serve-export.mjs",
    "check": "npm run lint && npm run format:check && npm run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "npm run check && npm run build"
  },
  "dependencies": {
    "@chakra-ui/react": "3.35.0",
    "@emotion/react": "11.14.0",
    "@fontsource/open-sans": "^4.5.13",
    "@fontsource/philosopher": "^4.5.11",
    "@mapequation/infomap": "^2.10.1",
    "@matejmazur/react-katex": "^3.1.3",
    "arg": "^5.0.2",
    "chakra-react-select": "6.1.1",
    "d3-force": "^3.0.0",
    "d3-quadtree": "^3.0.1",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.46",
    "localforage": "^1.10.0",
    "marked": "^18.0.3",
    "next": "15.5.15",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "^4.6.0",
    "shiki": "^4.0.2",
    "zod": "^4.4.3",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/d3-force": "^3.0.10",
    "@types/d3-quadtree": "^3.0.6",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.6"
  }
}
